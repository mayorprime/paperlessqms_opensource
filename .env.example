# Copy this file to .env and fill in the values before running docker-compose.

# PostgreSQL password (used by both postgres and backend services)
DB_PASSWORD=paperlessqms_secret

# JWT secret for token signing — MUST change in production.
# Generate a new one with: openssl rand -base64 64
JWT_SECRET=

# Public URL of the backend (used by Flutter web apps and mail links).
# Change this to your server's IP or domain when deploying.
BACKEND_URL=http://localhost:8080

# Host ports (change if 8080 or 80 are already in use on your machine)
BACKEND_PORT=8080
FLUTTER_PORT=80
